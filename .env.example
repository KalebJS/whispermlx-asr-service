# whispermlx ASR Service Configuration
# Native Apple-Silicon / MLX service

# ---------------------------------------------------------------------------
# Hugging Face Token (REQUIRED for speaker diarization)
# ---------------------------------------------------------------------------
# Get your token from https://huggingface.co/settings/tokens
# Accept the model agreement for:
#   https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=your_huggingface_token_here

# ---------------------------------------------------------------------------
# Device Configuration (MLX device semantics)
# ---------------------------------------------------------------------------
# DEVICE controls where VAD, wav2vec2 alignment, and pyannote diarization
# (torch-based stages) run.  MLX Whisper ASR always runs on the Metal GPU
# automatically regardless of this setting.
#
# Options:
#   cpu   - Safe default on Apple Silicon; torch stages on CPU, ASR on Metal GPU
#   mps   - Use Apple MPS for torch stages (experimental)
DEVICE=cpu

# ---------------------------------------------------------------------------
# Compute Type & Batch Size (accepted but INERT under MLX)
# ---------------------------------------------------------------------------
# These are read for API compatibility with the original CUDA-based service
# but have NO EFFECT on the MLX backend.  Whispermlx ignores compute_type
# and batch_size; setting them will not error but will not change inference
# behaviour either.
#COMPUTE_TYPE=int8
#BATCH_SIZE=2

# ---------------------------------------------------------------------------
# Model Cache Directories
# ---------------------------------------------------------------------------
# Where downloaded Whisper and alignment models are stored.
CACHE_DIR=~/.cache/whisperx-asr
# Hugging Face cache (pyannote diarization models); set to same as CACHE_DIR
# for unified caching.  Enables offline use after models are downloaded once.
HF_HOME=~/.cache/whisperx-asr

# Offline mode (OPTIONAL): set to 1 to prevent network requests to Hugging Face.
# Requires all models to be cached first (run once with internet access).
#HF_HUB_OFFLINE=1

# ---------------------------------------------------------------------------
# Model Preloading (OPTIONAL)
# ---------------------------------------------------------------------------
# Preload a specific model on startup to reduce first-request latency.
# Also sets the default model for /asr requests when no model= param is given.
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en,
#          large, large-v1, large-v2, large-v3, large-v3-turbo, turbo
# Leave empty or comment out to disable preloading.
PRELOAD_MODEL=large-v3

# Override which model the OpenAI "whisper-1" alias resolves to.
# Defaults to the PRELOAD_MODEL value, or large-v3 if unset.
#OPENAI_WHISPER1_MODEL=large-v3

# ---------------------------------------------------------------------------
# Service Port
# ---------------------------------------------------------------------------
# The service binds to this port.  Default is 9001.
# NOTE: entrypoint.sh hardcodes 9001; this is only respected when
# launching uvicorn directly with --port $PORT.
# (Port 9000 is reserved on this host; use the 9001-9010 range.)
PORT=9001

# ---------------------------------------------------------------------------
# Upload Limits
# ---------------------------------------------------------------------------
# Maximum audio file size in MB.  Default: 1000 MB (1 GB).
# MAX_FILE_SIZE_MB=1000

# ---------------------------------------------------------------------------
# GPU Concurrency & Queue
# ---------------------------------------------------------------------------
# Number of concurrent pipeline runs through the Metal GPU semaphore.
# Default: 1 (single-device serialisation).
# GPU_CONCURRENCY=1
# Maximum queued requests before rejecting with 503.  Default: 32.
# MAX_QUEUE_SIZE=32

# ---------------------------------------------------------------------------
# Idle Model Eviction (OPTIONAL)
# ---------------------------------------------------------------------------
# Unload Whisper models from memory after this many seconds of inactivity.
# The next request that needs the model will reload it transparently.
# Default 0 = disabled (models stay loaded indefinitely).
# Useful when you serve multiple models in rotation and want to reclaim memory.
# MODEL_KEEP_ALIVE_SECONDS=3600

# Sweep cadence for the eviction daemon (floor 30 seconds).
# MODEL_EVICTION_INTERVAL_SECONDS=60
